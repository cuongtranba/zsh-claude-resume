[27.328386, "o", "  \u001b[1mHow it works:\u001b[0m\r\n  \u001b[2m  - Per-directory: each project suggests its own last session\u001b[0m\r\n"]
[27.328568, "o", "  \u001b[2m  - Shows summary, time ago, and git branch\u001b[0m\r\n  \u001b[2m  - Arrow keys to navigate, Enter to select\u001b[0m\r\n  \u001b[2m  - Auto-detects flags from your history\u001b[0m\r\n  \u001b[2m  - Zero dependencies: pure ZSH + POSIX tools\u001b[0m\r\n\r\n"]
