[0.020052, "o", "\u001b[3J\u001b[H\u001b[2J"]
[0.020462, "o", "\r\n  \u001b[1mzsh-claude-resume\u001b[0m — auto-resume Claude Code sessions\r\n  ─────────────────────────────────────────────────────\r\n\r\n"]
[1.528767, "o", "  \u001b[2m# 1. Type 'claude' — ghost text suggests your last session\u001b[0m\r\n\r\n"]
