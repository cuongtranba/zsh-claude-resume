[22.663188, "o", "\r\n\r\n  \u001b[1mHow it works:\u001b[0m\r\n"]
[22.663276, "o", "  \u001b[2m  - Per-directory: each project suggests its own last session\u001b[0m\r\n  \u001b[2m  - Shows session summary, time ago, and git branch\u001b[0m\r\n  \u001b[2m  - Auto-detects flags from your history\u001b[0m\r\n  \u001b[2m  - Zero dependencies: pure ZSH + POSIX tools\u001b[0m\r\n\r\n"]
